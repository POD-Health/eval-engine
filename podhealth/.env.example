# PodHealth Eval — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# ── AWS Cognito ────────────────────────────────────────────────
AWS_REGION=us-east-1
COGNITO_CLIENT_ID=your_cognito_client_id
USER_POOL_ID=your_user_pool_id

# ── Test User Credentials ──────────────────────────────────────
TEST_USER_EMAIL=your_test_user@email.com
TEST_USER_PASSWORD=your_password

# ── Child IDs ──────────────────────────────────────────────────
CHILD1_ID=your_child1_id
CHILD2_ID=your_child2_id

# ── Piper API ──────────────────────────────────────────────────
DATA_AGENT_BASE_URL=https://your-api-url.com
CONVERSATION_BASE_URL=https://your-conversation-url.com
PARENT_DIAGNOSTIC_ID=your_diagnostic_id

# ── Excel Source ──────────────────────────────────────────────
# Path to the Excel file with test questions
EVAL_EXCEL_PATH=podhealth/questions.xlsx

# ── Grading Judge ─────────────────────────────────────────────
# Provider ID for llm-rubric judge — change to swap models
# Examples:
#   groq:llama-3.3-70b-versatile
#   anthropic:messages:claude-haiku-4-5-20251001
#   openai:gpt-4o-mini
GRADING_PROVIDER=groq:llama-3.3-70b-versatile

# API key for whichever provider you chose above
GRADING_PROVIDER_API_KEY=your_api_key_here


